    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "storybook": "^8.6.18",
    "typescript": "~5.8.3",
    "vite": "^6.4.1",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^3.1.3",
    "vue-tsc": "^2.2.10"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
